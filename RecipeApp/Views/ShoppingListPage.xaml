<Page x:Class="RecipeApp.Views.ShoppingListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RecipeApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Shopping List"
      Loaded="Page_Loaded">

    <Grid>
        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,20" MaxWidth="900">
                <!-- Page Title -->
                <TextBlock Text="🛒 Shopping List" 
                          FontSize="32" 
                          FontWeight="Bold" 
                          Foreground="#A62B60"
                          Margin="0,0,0,10"/>

                <TextBlock Text="Automatically generated from your meal plan" 
                          FontSize="14" 
                          Foreground="#666666"
                          Margin="0,0,0,30"/>

                <!-- Week Selection -->
                <Border Background="White"
                       BorderBrush="#CCCCCC"
                       BorderThickness="1"
                       CornerRadius="10"
                       Padding="20"
                       Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Select Week" 
                                  FontSize="18" 
                                  FontWeight="Bold" 
                                  Foreground="#A62B60"
                                  Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="WeekRangeText"
                                          Text="Week of..."
                                          FontSize="16"
                                          FontWeight="Bold"
                                          Margin="0,0,0,5"/>
                                <TextBlock x:Name="MealCountText"
                                          Text="0 meals planned"
                                          FontSize="13"
                                          Foreground="#666666"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="← Previous Week"
                                       Click="PreviousWeek_Click"
                                       Background="#97BC62"
                                       Foreground="White"
                                       BorderThickness="0"
                                       Padding="12,8"
                                       Margin="0,0,10,0"
                                       FontSize="13"
                                       Cursor="Hand"/>

                                <Button Content="This Week"
                                       Click="ThisWeek_Click"
                                       Background="#A62B60"
                                       Foreground="White"
                                       BorderThickness="0"
                                       Padding="12,8"
                                       Margin="0,0,10,0"
                                       FontSize="13"
                                       Cursor="Hand"/>

                                <Button Content="Next Week →"
                                       Click="NextWeek_Click"
                                       Background="#97BC62"
                                       Foreground="White"
                                       BorderThickness="0"
                                       Padding="12,8"
                                       FontSize="13"
                                       Cursor="Hand"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="🔄 Generate Shopping List"
                               Click="GenerateList_Click"
                               Background="#A62B60"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="20,12"
                               Margin="0,20,0,0"
                               FontSize="16"
                               FontWeight="Bold"
                               Cursor="Hand"
                               HorizontalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                       CornerRadius="5"
                                                       Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#8A2350"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Shopping List Display -->
                <Border x:Name="ShoppingListPanel"
                       Background="White"
                       BorderBrush="#CCCCCC"
                       BorderThickness="1"
                       CornerRadius="10"
                       Padding="20"
                       Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                      Text="Your Shopping List" 
                                      FontSize="20" 
                                      FontWeight="Bold" 
                                      Foreground="#A62B60"/>

                            <Button Grid.Column="1"
                                   Content="📋 Copy to Clipboard"
                                   Click="CopyList_Click"
                                   Background="#97BC62"
                                   Foreground="White"
                                   BorderThickness="0"
                                   Padding="12,6"
                                   FontSize="12"
                                   Cursor="Hand"/>
                        </Grid>

                        <!-- Ingredients List -->
                        <ItemsControl x:Name="IngredientsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F5F5F5"
                                           BorderBrush="#CCCCCC"
                                           BorderThickness="1"
                                           CornerRadius="5"
                                           Padding="12"
                                           Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                     IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,10,0"/>

                                            <TextBlock Grid.Column="1"
                                                      Text="{Binding Name}"
                                                      FontSize="14"
                                                      VerticalAlignment="Center"
                                                      TextWrapping="Wrap"/>

                                            <TextBlock Grid.Column="2"
                                                      Text="{Binding UsedInRecipes}"
                                                      FontSize="11"
                                                      Foreground="#666666"
                                                      VerticalAlignment="Center"
                                                      Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Empty State -->
                <Border x:Name="EmptyStatePanel"
                       Background="White"
                       BorderBrush="#CCCCCC"
                       BorderThickness="1"
                       CornerRadius="10"
                       Padding="40"
                       Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📝" 
                                  FontSize="64"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,20"/>
                        <TextBlock Text="No Meals Planned Yet" 
                                  FontSize="20"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,10"/>
                        <TextBlock Text="Add some meals to your meal planner first, then come back here to generate your shopping list!" 
                                  FontSize="14"
                                  Foreground="#666666"
                                  TextAlignment="Center"
                                  TextWrapping="Wrap"
                                  MaxWidth="400"
                                  Margin="0,0,0,20"/>
                        <Button Content="Go to Meal Planner"
                               Click="GoToMealPlanner_Click"
                               Background="#A62B60"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="20,10"
                               FontSize="14"
                               Cursor="Hand"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
