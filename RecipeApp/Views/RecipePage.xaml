<Window x:Class="RecipeApp.Views.RecipePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RecipeApp.Views"
        mc:Ignorable="d"
        Title="Browse Recipes" Height="700" Width="1000" 
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#A62B60" Padding="20">
            <TextBlock Text="Browse Recipes from DummyJSON API" 
                      FontSize="28" 
                      FontWeight="Bold" 
                      Foreground="White"
                      HorizontalAlignment="Center"/>
        </Border>

        <!-- Loading indicator -->
        <StackPanel Grid.Row="1"
                   x:Name="LoadingPanel"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Visible">
            <TextBlock Text="🔄 Loading recipes from API..." 
                      FontSize="20"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>
            <TextBlock Text="Please wait..." 
                      FontSize="14"
                      Foreground="#666666"
                      HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Recipe List -->
        <ScrollViewer Grid.Row="1" 
                     x:Name="RecipeScrollViewer" 
                     Visibility="Collapsed"
                     VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Recipe count -->
                <TextBlock x:Name="RecipeCountText"
                          FontSize="16"
                          Foreground="#666666"
                          Margin="0,0,0,15"
                          HorizontalAlignment="Center"/>

                <!-- Recipe items -->
                <ItemsControl x:Name="RecipeList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" 
                                   BorderBrush="#97BC62" 
                                   BorderThickness="2" 
                                   CornerRadius="8" 
                                   Padding="20" 
                                   Margin="0,0,0,15"
                                   MouseEnter="RecipeBorder_MouseEnter"
                                   MouseLeave="RecipeBorder_MouseLeave">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Recipe Image -->
                                    <Border Grid.Column="0" 
                                           CornerRadius="8"
                                           Background="#F5F5F5"
                                           Margin="0,0,20,0">
                                        <Image Source="{Binding ImageUrl}" 
                                              Width="180" 
                                              Height="180" 
                                              Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- Recipe Info -->
                                    <StackPanel Grid.Column="1">
                                        <!-- Recipe Name -->
                                        <TextBlock Text="{Binding Name}" 
                                                  FontSize="24" 
                                                  FontWeight="Bold" 
                                                  Foreground="#2C5F2D"
                                                  TextWrapping="Wrap"/>

                                        <!-- Cuisine Type -->
                                        <Border Background="#97BC62" 
                                               CornerRadius="12"
                                               Padding="8,3"
                                               HorizontalAlignment="Left"
                                               Margin="0,8,0,0">
                                            <TextBlock Text="{Binding CuisineType}" 
                                                      FontSize="12" 
                                                      Foreground="White"
                                                      FontWeight="Bold"/>
                                        </Border>

                                        <!-- Cooking Info -->
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <TextBlock Text="⏱️ Prep: " FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding PrepTimeMinutes}" FontSize="14"/>
                                            <TextBlock Text=" min" FontSize="14" Margin="0,0,15,0"/>

                                            <TextBlock Text="🍳 Cook: " FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding CookTimeMinutes}" FontSize="14"/>
                                            <TextBlock Text=" min" FontSize="14" Margin="0,0,15,0"/>

                                            <TextBlock Text="👥 Servings: " FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Servings}" FontSize="14"/>
                                        </StackPanel>

                                        <!-- Difficulty -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="📊 Difficulty: " FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Difficulty}" 
                                                      FontSize="14" 
                                                      FontWeight="Bold"
                                                      Foreground="#97BC62"/>
                                        </StackPanel>

                                        <!-- Ingredients -->
                                        <TextBlock Text="🥘 Ingredients:" 
                                                  FontWeight="Bold" 
                                                  FontSize="14"
                                                  Margin="0,12,0,5"/>
                                        <TextBlock Text="{Binding IngredientsDisplay}" 
                                                  TextWrapping="Wrap" 
                                                  FontSize="13"
                                                  Foreground="#333333"
                                                  LineHeight="20"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Error message -->
        <StackPanel Grid.Row="1"
                   x:Name="ErrorPanel"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed"
                   Margin="40">
            <TextBlock Text="❌ Error Loading Recipes" 
                      FontSize="24"
                      FontWeight="Bold"
                      Foreground="#990011"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>
            <TextBlock x:Name="ErrorMessage"
                      FontSize="16"
                      Foreground="#666666"
                      TextWrapping="Wrap"
                      TextAlignment="Center"
                      MaxWidth="600"/>
            <Button Content="Try Again"
                   Click="TryAgain_Click"
                   Margin="0,20,0,0"
                   Padding="20,10"
                   FontSize="16"
                   Background="#2C5F2D"
                   Foreground="White"
                   BorderThickness="0"
                   Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
