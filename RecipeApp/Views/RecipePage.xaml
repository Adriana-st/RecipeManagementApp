<Page x:Class="RecipeApp.Views.RecipePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RecipeApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Browse Recipes"
      Loaded="Page_Loaded">

    <Grid>

        <!-- Loading Panel -->
        <StackPanel x:Name="LoadingPanel"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Visible">
            <TextBlock Text="🔄 Loading recipes..." 
                      FontSize="20"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>
            <TextBlock Text="Please wait while we fetch recipes from the API" 
                      FontSize="14"
                      Foreground="#666666"
                      HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Recipes Display -->
        <ScrollViewer x:Name="RecipesPanel"
                     Visibility="Collapsed"
                     VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!-- Page Title -->
                <TextBlock Text="Browse Recipes" 
                  FontSize="28" 
                  FontWeight="Bold" 
                  Foreground="#A62B60"
                  Margin="0,0,0,20"/>

                <!-- Recipe Count -->
                <TextBlock x:Name="RecipeCountText"
                          FontSize="16"
                          Foreground="#666666"
                          Margin="0,0,0,15"
                          HorizontalAlignment="Center"/>

                <!-- Recipe List -->
                <ItemsControl x:Name="RecipeList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   CornerRadius="5"
                                   Padding="15"
                                   Margin="0,0,0,15"
                                   MouseEnter="RecipeBorder_MouseEnter"
                                   MouseLeave="RecipeBorder_MouseLeave">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Recipe Image -->
                                    <Border Grid.Column="0"
                                           Background="#F5F5F5"
                                           CornerRadius="5"
                                           Margin="0,0,15,0">
                                        <Image Source="{Binding ImageUrl}"
                                              Width="140"
                                              Height="140"
                                              Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- Recipe Info -->
                                    <StackPanel Grid.Column="1">
                                        <!-- Name -->
                                        <TextBlock Text="{Binding Name}"
                                                  FontSize="20"
                                                  FontWeight="Bold"
                                                  Foreground="#A62B60"
                                                  TextWrapping="Wrap"/>

                                        <!-- Cuisine -->
                                        <Border Background="#97BC62"
                                               CornerRadius="10"
                                               Padding="6,2"
                                               HorizontalAlignment="Left"
                                               Margin="0,5,0,0">
                                            <TextBlock Text="{Binding CuisineType}"
                                                      FontSize="11"
                                                      Foreground="White"
                                                      FontWeight="Bold"/>
                                        </Border>

                                        <!-- Times and Servings -->
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="⏱️ Prep: " FontSize="13" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding PrepTimeMinutes}" FontSize="13"/>
                                            <TextBlock Text=" min  |  " FontSize="13"/>

                                            <TextBlock Text="🍳 Cook: " FontSize="13" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding CookTimeMinutes}" FontSize="13"/>
                                            <TextBlock Text=" min  |  " FontSize="13"/>

                                            <TextBlock Text="👥 Serves: " FontSize="13" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Servings}" FontSize="13"/>
                                        </StackPanel>

                                        <!-- Difficulty -->
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="📊 Difficulty: " FontSize="13" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Difficulty}"
                                                      FontSize="13"
                                                      FontWeight="Bold"
                                                      Foreground="#97BC62"/>
                                        </StackPanel>

                                        <!-- Ingredients -->
                                        <TextBlock Text="🥘 Ingredients:"
                                                  FontWeight="Bold"
                                                  FontSize="13"
                                                  Margin="0,10,0,3"/>
                                        <TextBlock Text="{Binding IngredientsDisplay}"
                                                  TextWrapping="Wrap"
                                                  FontSize="12"
                                                  Foreground="#333333"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Error Panel -->
        <StackPanel x:Name="ErrorPanel"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed">
            <TextBlock Text="❌ Error Loading Recipes"
                      FontSize="20"
                      FontWeight="Bold"
                      Foreground="Red"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>
            <TextBlock x:Name="ErrorText"
                      FontSize="14"
                      Foreground="#666666"
                      TextWrapping="Wrap"
                      TextAlignment="Center"
                      MaxWidth="400"
                      Margin="0,0,0,15"/>
            <Button Content="Try Again"
                   Click="TryAgain_Click"
                   Padding="15,8"
                   Background="#A62B60"
                   Foreground="White"
                   BorderThickness="0"
                   Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Page>
