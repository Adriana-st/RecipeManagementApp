<Page x:Class="RecipeApp.Views.MealPlannerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RecipeApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Meal Planner"
      Loaded="Page_Loaded">

    <Grid>
        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,20">
                <!-- Page Title -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="📅 Meal Planner" 
                                  FontSize="32" 
                                  FontWeight="Bold" 
                                  Foreground="#A62B60"
                                  Margin="0,0,0,5"/>
                        <TextBlock x:Name="WeekRangeText"
                                  Text="Week of..."
                                  FontSize="14"
                                  Foreground="#666666"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="← Previous Week"
                               Click="PreviousWeek_Click"
                               Background="#97BC62"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="15,8"
                               Margin="0,0,10,0"
                               FontSize="13"
                               Cursor="Hand"/>

                        <Button Content="This Week"
                               Click="ThisWeek_Click"
                               Background="#A62B60"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="15,8"
                               Margin="0,0,10,0"
                               FontSize="13"
                               Cursor="Hand"/>

                        <Button Content="Next Week →"
                               Click="NextWeek_Click"
                               Background="#97BC62"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="15,8"
                               FontSize="13"
                               Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <!-- Weekly Calendar -->
                <Border Background="White"
                       BorderBrush="#CCCCCC"
                       BorderThickness="1"
                       CornerRadius="10"
                       Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Monday -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <Border Background="#A62B60" Padding="10,5" CornerRadius="5,5,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="Monday_Date" Text="Monday" FontWeight="Bold" Foreground="White" FontSize="13" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="Monday_Day" Text="15" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1,0,1,1" Padding="5" MinHeight="400">
                                <StackPanel x:Name="MondayMeals"/>
                            </Border>
                            <Button Content="+ Add Meal"
                                   Tag="Monday"
                                   Click="AddMeal_Click"
                                   Background="#F5F5F5"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   Padding="5"
                                   FontSize="11"
                                   Cursor="Hand"
                                   Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Tuesday -->
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <Border Background="#A62B60" Padding="10,5" CornerRadius="5,5,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="Tuesday_Date" Text="Tuesday" FontWeight="Bold" Foreground="White" FontSize="13" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="Tuesday_Day" Text="16" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1,0,1,1" Padding="5" MinHeight="400">
                                <StackPanel x:Name="TuesdayMeals"/>
                            </Border>
                            <Button Content="+ Add Meal"
                                   Tag="Tuesday"
                                   Click="AddMeal_Click"
                                   Background="#F5F5F5"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   Padding="5"
                                   FontSize="11"
                                   Cursor="Hand"
                                   Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Wednesday -->
                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <Border Background="#A62B60" Padding="10,5" CornerRadius="5,5,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="Wednesday_Date" Text="Wednesday" FontWeight="Bold" Foreground="White" FontSize="13" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="Wednesday_Day" Text="17" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1,0,1,1" Padding="5" MinHeight="400">
                                <StackPanel x:Name="WednesdayMeals"/>
                            </Border>
                            <Button Content="+ Add Meal"
                                   Tag="Wednesday"
                                   Click="AddMeal_Click"
                                   Background="#F5F5F5"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   Padding="5"
                                   FontSize="11"
                                   Cursor="Hand"
                                   Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Thursday -->
                        <StackPanel Grid.Column="3" Margin="0,0,10,0">
                            <Border Background="#A62B60" Padding="10,5" CornerRadius="5,5,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="Thursday_Date" Text="Thursday" FontWeight="Bold" Foreground="White" FontSize="13" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="Thursday_Day" Text="18" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1,0,1,1" Padding="5" MinHeight="400">
                                <StackPanel x:Name="ThursdayMeals"/>
                            </Border>
                            <Button Content="+ Add Meal"
                                   Tag="Thursday"
                                   Click="AddMeal_Click"
                                   Background="#F5F5F5"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   Padding="5"
                                   FontSize="11"
                                   Cursor="Hand"
                                   Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Friday -->
                        <StackPanel Grid.Column="4" Margin="0,0,10,0">
                            <Border Background="#A62B60" Padding="10,5" CornerRadius="5,5,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="Friday_Date" Text="Friday" FontWeight="Bold" Foreground="White" FontSize="13" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="Friday_Day" Text="19" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1,0,1,1" Padding="5" MinHeight="400">
                                <StackPanel x:Name="FridayMeals"/>
                            </Border>
                            <Button Content="+ Add Meal"
                                   Tag="Friday"
                                   Click="AddMeal_Click"
                                   Background="#F5F5F5"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   Padding="5"
                                   FontSize="11"
                                   Cursor="Hand"
                                   Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Saturday -->
                        <StackPanel Grid.Column="5" Margin="0,0,10,0">
                            <Border Background="#97BC62" Padding="10,5" CornerRadius="5,5,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="Saturday_Date" Text="Saturday" FontWeight="Bold" Foreground="White" FontSize="13" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="Saturday_Day" Text="20" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1,0,1,1" Padding="5" MinHeight="400">
                                <StackPanel x:Name="SaturdayMeals"/>
                            </Border>
                            <Button Content="+ Add Meal"
                                   Tag="Saturday"
                                   Click="AddMeal_Click"
                                   Background="#F5F5F5"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   Padding="5"
                                   FontSize="11"
                                   Cursor="Hand"
                                   Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Sunday -->
                        <StackPanel Grid.Column="6">
                            <Border Background="#97BC62" Padding="10,5" CornerRadius="5,5,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="Sunday_Date" Text="Sunday" FontWeight="Bold" Foreground="White" FontSize="13" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="Sunday_Day" Text="21" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1,0,1,1" Padding="5" MinHeight="400">
                                <StackPanel x:Name="SundayMeals"/>
                            </Border>
                            <Button Content="+ Add Meal"
                                   Tag="Sunday"
                                   Click="AddMeal_Click"
                                   Background="#F5F5F5"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   Padding="5"
                                   FontSize="11"
                                   Cursor="Hand"
                                   Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="🗑️ Clear Week"
                           Click="ClearWeek_Click"
                           Background="#990011"
                           Foreground="White"
                           BorderThickness="0"
                           Padding="20,10"
                           FontSize="14"
                           FontWeight="Bold"
                           Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
