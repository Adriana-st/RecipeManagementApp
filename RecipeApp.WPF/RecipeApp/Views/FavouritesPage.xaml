<Page x:Class="RecipeApp.Views.FavouritesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RecipeApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FavouritesPage"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading Panel -->
        <StackPanel Grid.Row="1"
                   x:Name="LoadingPanel"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Visible">
            <TextBlock Text="🔄 Loading your favourites..." 
                      FontSize="20"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>
            <TextBlock Text="Please wait..." 
                      FontSize="14"
                      Foreground="#666666"
                      HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Empty State -->
        <StackPanel Grid.Row="1"
                   x:Name="EmptyPanel"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed"
                   Margin="40">
            <TextBlock Text="📖" 
                      FontSize="72"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,20"/>
            <TextBlock Text="No Favourites Yet" 
                      FontSize="24"
                      FontWeight="Bold"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>
            <TextBlock Text="Browse recipes and click 'Save to Favourites' to add them here!" 
                      FontSize="14"
                      Foreground="#666666"
                      TextAlignment="Center"
                      TextWrapping="Wrap"
                      MaxWidth="400"
                      Margin="0,0,0,20"/>
            <Button Content="Browse Recipes"
                   Click="BrowseRecipes_Click"
                   Background="#A62B60"
                   Foreground="White"
                   BorderThickness="0"
                   Padding="20,10"
                   FontSize="16"
                   Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#A62B60"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                           CornerRadius="5"
                                           Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#8A2350"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Favourites List -->
        <ScrollViewer Grid.Row="1"
                     x:Name="FavouritesPanel"
                     Visibility="Collapsed"
                     VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Page Title -->
                <TextBlock Text="My Favourite Recipes" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="#A62B60"
                           Margin="0,0,0,20"/>

                <!-- Recipe Count -->
                <TextBlock x:Name="CountText"
                    FontSize="16"
                    Foreground="#666666"
                    Margin="0,0,0,15"
                    HorizontalAlignment="Center"/>
                
                <!-- Recipe List -->
                <ItemsControl x:Name="FavouritesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   CornerRadius="5"
                                   Padding="15"
                                   Margin="0,0,0,15"
                                   MouseEnter="RecipeBorder_MouseEnter"
                                   MouseLeave="RecipeBorder_MouseLeave">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Recipe Image -->
                                    <Border Grid.Column="0"
                                           Background="#F5F5F5"
                                           CornerRadius="5"
                                           Margin="0,0,15,0">
                                        <Image Source="{Binding ImageUrl}"
                                              Width="140"
                                              Height="140"
                                              Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- Recipe Info -->
                                    <StackPanel Grid.Column="1">
                                        <!-- Name -->
                                        <TextBlock Text="{Binding Name}"
                                                  FontSize="20"
                                                  FontWeight="Bold"
                                                  Foreground="#A62B60"
                                                  TextWrapping="Wrap"/>

                                        <!-- Cuisine -->
                                        <Border Background="#97BC62"
                                               CornerRadius="10"
                                               Padding="6,2"
                                               HorizontalAlignment="Left"
                                               Margin="0,5,0,0">
                                            <TextBlock Text="{Binding CuisineType}"
                                                      FontSize="11"
                                                      Foreground="White"
                                                      FontWeight="Bold"/>
                                        </Border>

                                        <!-- Times and Servings -->
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="⏱️ Prep: " FontSize="13" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding PrepTimeMinutes}" FontSize="13"/>
                                            <TextBlock Text=" min  |  " FontSize="13"/>

                                            <TextBlock Text="🍳 Cook: " FontSize="13" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding CookTimeMinutes}" FontSize="13"/>
                                            <TextBlock Text=" min  |  " FontSize="13"/>

                                            <TextBlock Text="👥 Serves: " FontSize="13" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Servings}" FontSize="13"/>
                                        </StackPanel>

                                        <!-- Difficulty -->
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="📊 Difficulty: " FontSize="13" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Difficulty}"
                                                      FontSize="13"
                                                      FontWeight="Bold"
                                                      Foreground="#97BC62"/>
                                        </StackPanel>

                                        <!-- Date Added -->
                                        <TextBlock Margin="0,5,0,0">
                                            <Run Text="💾 Saved: " FontWeight="Bold" FontSize="12"/>
                                            <Run Text="{Binding DateAdded, StringFormat='dd/MM/yyyy HH:mm'}" FontSize="12" Foreground="#666666"/>
                                        </TextBlock>

                                        <!-- Ingredients -->
                                        <TextBlock Text="🥘 Ingredients:"
                                                  FontWeight="Bold"
                                                  FontSize="13"
                                                  Margin="0,10,0,3"/>
                                        <TextBlock Text="{Binding IngredientsDisplay}"
                                                  TextWrapping="Wrap"
                                                  FontSize="12"
                                                  Foreground="#333333"/>

                                        <!-- Remove Button -->
                                        <Button Content="🗑️ Remove from Favourites"
                                               Click="RemoveFromFavourites_Click"
                                               Tag="{Binding}"
                                               Background="#990011"
                                               Foreground="White"
                                               BorderThickness="0"
                                               Padding="12,6"
                                               Margin="0,10,0,0"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Cursor="Hand"
                                               HorizontalAlignment="Left">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#990011"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                       CornerRadius="5"
                                                                       Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#770000"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
