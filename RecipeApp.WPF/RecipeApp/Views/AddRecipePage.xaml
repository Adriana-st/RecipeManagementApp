<Page x:Class="RecipeApp.Views.AddRecipePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RecipeApp.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add Custom Recipe">

    <Grid>
        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,20" MaxWidth="900">
                <!-- Page Title -->
                <TextBlock Text="✨ Add Your Own Recipe" 
                          FontSize="32" 
                          FontWeight="Bold" 
                          Foreground="#A62B60"
                          Margin="0,0,0,10"/>

                <TextBlock Text="Create and save your own custom recipes" 
                          FontSize="14" 
                          Foreground="#666666"
                          Margin="0,0,0,30"/>

                <!-- Form Card -->
                <Border Background="White"
                       BorderBrush="#CCCCCC"
                       BorderThickness="1"
                       CornerRadius="10"
                       Padding="30">
                    <StackPanel>
                        <!-- Basic Information -->
                        <TextBlock Text="Basic Information" 
                                  FontSize="20" 
                                  FontWeight="Bold" 
                                  Foreground="#A62B60"
                                  Margin="0,0,0,20"/>

                        <!-- Recipe Name -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Recipe Name *" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                            <TextBox x:Name="RecipeNameBox"
                                    Padding="10"
                                    FontSize="14"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"/>
                        </StackPanel>

                        <!-- Description -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Description" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                            <TextBox x:Name="DescriptionBox"
                                    Padding="10"
                                    FontSize="14"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    Height="80"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"/>
                        </StackPanel>

                        <!-- Row 1: Cuisine and Difficulty -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cuisine Type -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Cuisine Type *" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <ComboBox x:Name="CuisineBox"
                                         Padding="10"
                                         FontSize="14"
                                         BorderBrush="#CCCCCC">
                                    <ComboBoxItem Content="Italian"/>
                                    <ComboBoxItem Content="Asian"/>
                                    <ComboBoxItem Content="American"/>
                                    <ComboBoxItem Content="Mexican"/>
                                    <ComboBoxItem Content="Indian"/>
                                    <ComboBoxItem Content="Mediterranean"/>
                                    <ComboBoxItem Content="Japanese"/>
                                    <ComboBoxItem Content="Thai"/>
                                    <ComboBoxItem Content="Greek"/>
                                    <ComboBoxItem Content="Other"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Difficulty -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Difficulty *" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <ComboBox x:Name="DifficultyBox"
                                         Padding="10"
                                         FontSize="14"
                                         BorderBrush="#CCCCCC">
                                    <ComboBoxItem Content="Easy"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="Hard"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: Times and Servings -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Prep Time -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Prep Time (min) *" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <TextBox x:Name="PrepTimeBox"
                                        Padding="10"
                                        FontSize="14"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="1"/>
                            </StackPanel>

                            <!-- Cook Time -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Cook Time (min) *" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <TextBox x:Name="CookTimeBox"
                                        Padding="10"
                                        FontSize="14"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="1"/>
                            </StackPanel>

                            <!-- Servings -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Servings *" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <TextBox x:Name="ServingsBox"
                                        Padding="10"
                                        FontSize="14"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="1"/>
                            </StackPanel>
                        </Grid>

                        <!-- Image URL -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Image URL (optional)" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                            <TextBox x:Name="ImageUrlBox"
                                    Padding="10"
                                    FontSize="14"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"/>
                            <TextBlock Text="You can paste a URL to an image (e.g., from Google Images)" 
                                      FontSize="11" 
                                      Foreground="#666666" 
                                      Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Height="1" Background="#CCCCCC" Margin="0,20,0,20"/>

                        <!-- Ingredients Section -->
                        <TextBlock Text="🥘 Ingredients" 
                                  FontSize="20" 
                                  FontWeight="Bold" 
                                  Foreground="#A62B60"
                                  Margin="0,0,0,15"/>

                        <!-- Ingredients Input -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="IngredientBox"
                                    Grid.Column="0"
                                    Padding="10"
                                    FontSize="14"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    KeyUp="IngredientBox_KeyUp"/>

                            <Button Grid.Column="1"
                                   Content="➕ Add"
                                   Click="AddIngredient_Click"
                                   Background="#97BC62"
                                   Foreground="White"
                                   BorderThickness="0"
                                   Padding="20,10"
                                   Margin="5,0,0,0"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Cursor="Hand"/>
                        </Grid>

                        <!-- Ingredients List -->
                        <Border Background="#F5F5F5"
                               BorderBrush="#CCCCCC"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="15"
                               Margin="0,0,0,20"
                               MinHeight="100">
                            <StackPanel>
                                <TextBlock Text="Added Ingredients:" FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>
                                <ItemsControl x:Name="IngredientsListView">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White"
                                                   BorderBrush="#CCCCCC"
                                                   BorderThickness="1"
                                                   CornerRadius="3"
                                                   Padding="8"
                                                   Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="✓" Foreground="#97BC62" FontWeight="Bold" Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding}" FontSize="13" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2"
                                                           Content="❌"
                                                           Click="RemoveIngredient_Click"
                                                           Tag="{Binding}"
                                                           Background="Transparent"
                                                           BorderThickness="0"
                                                           Cursor="Hand"
                                                           FontSize="11"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Separator -->
                        <Border Height="1" Background="#CCCCCC" Margin="0,0,0,20"/>

                        <!-- Instructions Section -->
                        <TextBlock Text="📖 Instructions" 
                                  FontSize="20" 
                                  FontWeight="Bold" 
                                  Foreground="#A62B60"
                                  Margin="0,0,0,15"/>

                        <!-- Instructions Input -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="InstructionBox"
                                    Grid.Column="0"
                                    Padding="10"
                                    FontSize="14"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    Height="60"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"/>

                            <Button Grid.Column="1"
                                   Content="➕ Add Step"
                                   Click="AddInstruction_Click"
                                   Background="#97BC62"
                                   Foreground="White"
                                   BorderThickness="0"
                                   Padding="15,10"
                                   Margin="5,0,0,0"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Cursor="Hand"
                                   VerticalAlignment="Top"/>
                        </Grid>

                        <!-- Instructions List -->
                        <Border Background="#F5F5F5"
                               BorderBrush="#CCCCCC"
                               BorderThickness="1"
                               CornerRadius="5"
                               Padding="15"
                               Margin="0,0,0,30"
                               MinHeight="100">
                            <StackPanel>
                                <TextBlock Text="Added Steps:" FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>
                                <ItemsControl x:Name="InstructionsListView">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White"
                                                   BorderBrush="#CCCCCC"
                                                   BorderThickness="1"
                                                   CornerRadius="3"
                                                   Padding="10"
                                                   Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                           Background="#A62B60"
                                                           CornerRadius="15"
                                                           Width="25"
                                                           Height="25"
                                                           Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding StepNumber}" 
                                                                  Foreground="White"
                                                                  FontWeight="Bold"
                                                                  FontSize="12"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" 
                                                              Text="{Binding Instruction}" 
                                                              FontSize="13" 
                                                              TextWrapping="Wrap"
                                                              VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2"
                                                           Content="❌"
                                                           Click="RemoveInstruction_Click"
                                                           Tag="{Binding StepNumber}"
                                                           Background="Transparent"
                                                           BorderThickness="0"
                                                           Cursor="Hand"
                                                           FontSize="11"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="💾 Save Recipe"
                                   Click="SaveRecipe_Click"
                                   Background="#A62B60"
                                   Foreground="White"
                                   BorderThickness="0"
                                   Padding="30,12"
                                   Margin="0,0,15,0"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                           CornerRadius="5"
                                                           Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#8A2350"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="🔄 Clear Form"
                                   Click="ClearForm_Click"
                                   Background="#97BC62"
                                   Foreground="White"
                                   BorderThickness="0"
                                   Padding="30,12"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                           CornerRadius="5"
                                                           Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#7A9B50"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
