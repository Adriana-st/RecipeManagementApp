<Window x:Class="RecipeApp.Views.AddMealDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RecipeApp.Views"
        mc:Ignorable="d"
        Title="Add Meal to Plan"
        Height="540"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                  Text="Add Meal to Plan" 
                  FontSize="24" 
                  FontWeight="Bold" 
                  Foreground="#A62B60"
                  Margin="0,0,0,20"/>

        <!-- Meal Type Selection -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Meal Type" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox x:Name="MealTypeBox"
                     Padding="10"
                     FontSize="14">
                <ComboBoxItem Content="Breakfast" IsSelected="True"/>
                <ComboBoxItem Content="Lunch"/>
                <ComboBoxItem Content="Dinner"/>
                <ComboBoxItem Content="Snack"/>
            </ComboBox>
        </StackPanel>

        <!-- Recipe Selection -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Select Recipe" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>

            <Border BorderBrush="#CCCCCC"
                   BorderThickness="1"
                   CornerRadius="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="250">
                    <ItemsControl x:Name="RecipesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                       BorderBrush="#CCCCCC"
                                       BorderThickness="0,0,0,1"
                                       Padding="10"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="Recipe_Click"
                                       Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" 
                                                  FontWeight="Bold" 
                                                  FontSize="14"/>
                                        <TextBlock Text="{Binding CuisineType}" 
                                                  FontSize="12" 
                                                  Foreground="#666666"
                                                  Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock x:Name="NoRecipesText"
                      Text="No favourite recipes available. Add some recipes to favourites first!"
                      FontSize="13"
                      Foreground="#666666"
                      TextWrapping="Wrap"
                      Margin="0,10,0,0"
                      Visibility="Collapsed"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,20,0,0">
            <Button Content="Cancel"
                   Click="Cancel_Click"
                   Background="#CCCCCC"
                   Foreground="#333333"
                   BorderThickness="0"
                   Padding="20,10"
                   Margin="0,0,10,0"
                   FontSize="14"
                   Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
