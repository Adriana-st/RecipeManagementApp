<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:RecipeApp.MAUI.Helpers"
             x:Class="RecipeApp.MAUI.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <helpers:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
            <helpers:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <helpers:BoolToStrikethroughConverter x:Key="BoolToStrikethroughConverter"/>
            <helpers:BoolToGrayConverter x:Key="BoolToGrayConverter"/>
            <helpers:IsNotNullOrEmptyConverter x:Key="IsNotNullOrEmptyConverter"/>
            <helpers:BoolToSaveTextConverter x:Key="BoolToSaveTextConverter"/>
            <helpers:BoolToSaveColorConverter x:Key="BoolToSaveColorConverter"/>
            <helpers:BoolToFilterButtonColorConverter x:Key="BoolToFilterButtonColorConverter"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>