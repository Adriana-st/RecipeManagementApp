<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RecipeApp.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RecipeApp.MAUI.Views"
    Shell.FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="#A62B60">

    <!-- Flyout Header -->
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="#8A2350" Padding="20" HeightRequest="150">
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="🍳"
                       FontSize="48"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Recipe Management"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Your culinary companion"
                       FontSize="12"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Menu Items -->
    <!-- Only HomePage for now -->
    <FlyoutItem Title="Home" Icon="home.png" Route="HomePage">
        <ShellContent ContentTemplate="{DataTemplate local:HomePage}" />
    </FlyoutItem>

    <!-- TODO: Add other pages when they are created -->
</Shell>
