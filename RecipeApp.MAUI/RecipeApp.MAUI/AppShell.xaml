<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RecipeApp.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RecipeApp.MAUI.Views"
    Shell.FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="#A62B60"
    Shell.ForegroundColor="White">

    <!-- Flyout Header -->
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="#8A2350" Padding="20" HeightRequest="150">
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="🍳" FontSize="48" HorizontalTextAlignment="Center"/>
                <Label Text="Recipe Management"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="White" HorizontalTextAlignment="Center"/>
                <Label Text="Your culinary companion"
                       FontSize="12" TextColor="White"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <Shell.Resources>
        <Style TargetType="Label" Class="FlyoutItemLabelStyle">
            <Setter Property="TextColor" Value="White" />
        </Style>
    </Shell.Resources>

    <!-- Pages -->
    <FlyoutItem Title="Home" Icon="home.png" Route="HomePage">
        <ShellContent ContentTemplate="{DataTemplate local:HomePage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Recipes" Icon="recipes.png" Route="RecipesPage">
        <ShellContent ContentTemplate="{DataTemplate local:RecipesPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Favourites" Icon="favourites.png" Route="FavouritesPage">
        <ShellContent ContentTemplate="{DataTemplate local:FavouritesPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Add Recipe" Icon="add.png" Route="AddRecipePage">
        <ShellContent ContentTemplate="{DataTemplate local:AddRecipePage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Meal Planner" Icon="planner.png" Route="MealPlannerPage">
        <ShellContent ContentTemplate="{DataTemplate local:MealPlannerPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Shopping List" Icon="shopping.png" Route="ShoppingListPage">
        <ShellContent ContentTemplate="{DataTemplate local:ShoppingListPage}"/>
    </FlyoutItem>

</Shell>