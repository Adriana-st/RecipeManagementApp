<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:RecipeApp.MAUI.ViewModels"
             x:Class="RecipeApp.MAUI.Views.ShoppingListPage"
             x:DataType="viewmodel:ShoppingListViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Week Navigation Header -->
        <Frame Grid.Row="0" 
               Style="{StaticResource PageHeaderStyle}" 
               Padding="10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="◀"
                        BackgroundColor="Transparent"
                        TextColor="White" FontSize="18"
                        Padding="10,0"
                        Command="{Binding PreviousWeekCommand}"/>

                <VerticalStackLayout Grid.Column="1"
                                     VerticalOptions="Center" Spacing="2">
                    <Label Text="Shopping List"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding WeekRangeText}"
                           FontSize="13" TextColor="White"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <Button Grid.Column="2"
                        Text="▶"
                        BackgroundColor="Transparent"
                        TextColor="White" FontSize="18"
                        Padding="10,0"
                        Command="{Binding NextWeekCommand}"/>
            </Grid>
        </Frame>

        <!-- Action Buttons -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*"
              ColumnSpacing="10" Padding="15,10">
            <Button Grid.Column="0"
                    Text="Generate"
                    Style="{StaticResource PrimaryButtonStyle}" 
                    FontSize="13"
                    Command="{Binding GenerateShoppingListCommand}"/>
            <Button Grid.Column="1"
                    Text="Copy"
                    Style="{StaticResource AccentButtonStyle}" 
                    FontSize="13"
                    Command="{Binding CopyToClipboardCommand}"/>
            <Button Grid.Column="2"
                    Text="Clear Done"
                    Style="{StaticResource SecondaryButtonStyle}" 
                    FontSize="13"
                    Command="{Binding ClearCheckedCommand}"/>
        </Grid>

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="2"
                             IsVisible="{Binding HasNoItems}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="15" Padding="40">
            <Label Text="No items yet!"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource AppTextPrimary}"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Navigate to a week and tap Generate to build your shopping list."
                   FontSize="15" TextColor="{StaticResource AppTextSecondary}"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Shopping Items -->
        <CollectionView Grid.Row="2"
                        IsVisible="{Binding HasNoItems, Converter={StaticResource InvertedBoolConverter}}"
                        ItemsSource="{Binding ShoppingItems}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodel:ShoppingItem">
                    <Grid Padding="15,4">
                        <Frame BackgroundColor="White" CornerRadius="8"
                               Padding="12,10" HasShadow="False">
                            <Grid ColumnDefinitions="Auto,*">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsChecked}"
                                          Color="{StaticResource AppPrimary}"/>
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       Margin="8,0,0,0"
                                       TextDecorations="{Binding IsChecked, Converter={StaticResource BoolToStrikethroughConverter}}"
                                       TextColor="{Binding IsChecked, Converter={StaticResource BoolToGrayConverter}}"/>
                            </Grid>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource AppPrimary}"
                           VerticalOptions="Center"/>

    </Grid>
</ContentPage>