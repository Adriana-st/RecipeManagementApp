<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:RecipeApp.MAUI.ViewModels"
             x:Class="RecipeApp.MAUI.Views.ShoppingListPage"
             x:DataType="viewmodel:ShoppingListViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Header -->
        <Frame Grid.Row="0" BackgroundColor="#A62B60" CornerRadius="0" Padding="20" HasShadow="False">
            <VerticalStackLayout Spacing="4">
                <Label Text="🛒 Shopping List"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="White" HorizontalTextAlignment="Center"/>
                <Label Text="{Binding WeekRangeText}"
                       FontSize="13" TextColor="White"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Frame>

        <!-- Action Buttons -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*"
              ColumnSpacing="10" Padding="15,10">
            <Button Grid.Column="0"
                    Text="🔄 Generate"
                    BackgroundColor="#A62B60"
                    TextColor="White"
                    FontSize="13"
                    CornerRadius="8"
                    Command="{Binding GenerateShoppingListCommand}"/>
            <Button Grid.Column="1"
                    Text="📋 Copy"
                    BackgroundColor="#97BC62"
                    TextColor="White"
                    FontSize="13"
                    CornerRadius="8"
                    Command="{Binding CopyToClipboardCommand}"/>
            <Button Grid.Column="2"
                    Text="🗑️ Clear Done"
                    BackgroundColor="#888"
                    TextColor="White"
                    FontSize="13"
                    CornerRadius="8"
                    Command="{Binding ClearCheckedCommand}"/>
        </Grid>

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="2"
                             IsVisible="{Binding HasNoItems}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="15" Padding="40">
            <Label Text="🛒" FontSize="64" HorizontalTextAlignment="Center"/>
            <Label Text="No items yet!"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="#333" HorizontalTextAlignment="Center"/>
            <Label Text="Add recipes to your meal planner then tap Generate."
                   FontSize="15" TextColor="Gray"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Shopping Items -->
        <CollectionView Grid.Row="2"
                        IsVisible="{Binding HasNoItems, Converter={StaticResource InvertedBoolConverter}}"
                        ItemsSource="{Binding ShoppingItems}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodel:ShoppingItem">
                    <Grid Padding="15,6">
                        <Frame BackgroundColor="White" CornerRadius="8"
                               Padding="15" HasShadow="False">
                            <Grid ColumnDefinitions="Auto,*">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsChecked}"
                                          Color="#A62B60"/>
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       Margin="10,0,0,0"
                                       TextDecorations="{Binding IsChecked, Converter={StaticResource BoolToStrikethroughConverter}}"
                                       TextColor="{Binding IsChecked, Converter={StaticResource BoolToGrayConverter}}"/>
                            </Grid>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#A62B60"
                           VerticalOptions="Center"/>

    </Grid>
</ContentPage>