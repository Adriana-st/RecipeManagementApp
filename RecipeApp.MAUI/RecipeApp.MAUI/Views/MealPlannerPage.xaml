<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:RecipeApp.MAUI.ViewModels"
             xmlns:models="clr-namespace:RecipeApp.Shared;assembly=RecipeApp.Shared"
             x:Class="RecipeApp.MAUI.Views.MealPlannerPage"
             x:DataType="viewmodel:MealPlannerViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">

        <!-- Week Navigation Header -->
        <Frame Grid.Row="0" Style="{StaticResource PageHeaderStyle}" Padding="10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="◀"
                        BackgroundColor="Transparent"
                        TextColor="White" FontSize="18"
                        Padding="10,0"
                        Command="{Binding PreviousWeekCommand}"/>

                <VerticalStackLayout Grid.Column="1"
                                     VerticalOptions="Center" Spacing="2">
                    <Label Text="Meal Planner"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding WeekRangeText}"
                           FontSize="13" TextColor="White"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <Button Grid.Column="2"
                        Text="▶"
                        BackgroundColor="Transparent"
                        TextColor="White" FontSize="18"
                        Padding="10,0"
                        Command="{Binding NextWeekCommand}"/>
            </Grid>
        </Frame>

        <!-- Week Days -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15" Spacing="12"
                                 BindableLayout.ItemsSource="{Binding WeekMeals}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewmodel:DayMeals">

                        <!-- Day Card -->
                        <Frame Padding="0" CornerRadius="12" HasShadow="True"
                               BackgroundColor="White"
                               BorderColor="{Binding IsToday, Converter={StaticResource BoolToColorConverter}}">

                            <VerticalStackLayout Spacing="0">

                                <!-- Day Card Header -->
                                <Grid ColumnDefinitions="*,Auto"
                                      Padding="15,10"
                                      BackgroundColor="{Binding IsToday, Converter={StaticResource BoolToDayHeaderColorConverter}}">

                                    <HorizontalStackLayout Grid.Column="0" Spacing="10">
                                        <Label Text="{Binding DayName}"
                                               FontSize="16" FontAttributes="Bold"
                                               TextColor="{Binding IsToday, Converter={StaticResource BoolToColorConverter}}"
                                               VerticalOptions="Center"/>
                                        <Label Text="{Binding ShortDate}"
                                               FontSize="13" TextColor="{StaticResource AppTextSecondary}"
                                               VerticalOptions="Center"/>
                                        <!-- Today badge -->
                                        <Frame IsVisible="{Binding IsToday}"
                                               BackgroundColor="{StaticResource AppPrimary}"
                                               CornerRadius="6" Padding="8,2"
                                               HasShadow="False">
                                            <Label Text="Today"
                                                   FontSize="11" TextColor="White"
                                                   FontAttributes="Bold"/>
                                        </Frame>
                                    </HorizontalStackLayout>

                                    <Button Grid.Column="1"
                                            Text="+ Add Meal"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            FontSize="12"
                                            Padding="12,6"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MealPlannerViewModel}}, Path=AddMealCommand}"
                                            CommandParameter="{Binding .}"/>
                                </Grid>

                                <!-- Divider -->
                                <BoxView HeightRequest="1" BackgroundColor="#EEE"/>

                                <!-- Empty state for day -->
                                <Label Text="No meals planned"
                                       FontSize="13" TextColor="#BBB"
                                       Padding="15,10"
                                       IsVisible="{Binding HasNoMeals}"
                                       HorizontalTextAlignment="Start"/>

                                <!-- Meals List -->
                                <VerticalStackLayout
                                    BindableLayout.ItemsSource="{Binding Meals}"
                                    Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:MealPlan">
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  Padding="12,8" ColumnSpacing="10">

                                                <!-- Meal Type Pill -->
                                                <Frame Grid.Column="0"
                                                       BackgroundColor="{Binding MealType, Converter={StaticResource MealTypeToColorConverter}}"
                                                       CornerRadius="6"
                                                       Padding="10,4"
                                                       HasShadow="False"
                                                       WidthRequest="85">
                                                    <Label Text="{Binding MealType}"
                                                           FontSize="12"
                                                           TextColor="White"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="Center"/>
                                                </Frame>

                                                <!-- Recipe Name -->
                                                <Label Grid.Column="1"
                                                       Text="{Binding RecipeName}"
                                                       FontSize="14"
                                                       TextColor="{StaticResource AppTextPrimary}"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation"/>

                                                <!-- Remove Button -->
                                                <Button Grid.Column="2"
                                                        Text="✕"
                                                        BackgroundColor="Transparent"
                                                        TextColor="#CCC"
                                                        FontSize="14"
                                                        Padding="8,0"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MealPlannerViewModel}}, Path=RemoveMealCommand}"
                                                        CommandParameter="{Binding .}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Frame>

                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>