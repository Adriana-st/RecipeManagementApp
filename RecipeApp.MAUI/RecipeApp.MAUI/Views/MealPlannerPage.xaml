<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:RecipeApp.MAUI.ViewModels"
             xmlns:models="clr-namespace:RecipeApp.MAUI.Models"
             x:Class="RecipeApp.MAUI.Views.MealPlannerPage"
             x:DataType="viewmodel:MealPlannerViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">

        <!-- Week Navigation -->
        <Frame Grid.Row="0" BackgroundColor="#A62B60" CornerRadius="0" Padding="15" HasShadow="False">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Text="◀"
                        BackgroundColor="Transparent"
                        TextColor="White" FontSize="20"
                        Command="{Binding PreviousWeekCommand}"/>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="📅 Meal Planner"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding WeekRangeText}"
                           FontSize="13" TextColor="White"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <Button Grid.Column="2" Text="▶"
                        BackgroundColor="Transparent"
                        TextColor="White" FontSize="20"
                        Command="{Binding NextWeekCommand}"/>
            </Grid>
        </Frame>

        <!-- Week Days -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding WeekMeals}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodel:DayMeals">
                    <VerticalStackLayout Padding="15,10" Spacing="8">

                        <!-- Day Header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding DayName}"
                                       FontSize="17" FontAttributes="Bold"
                                       TextColor="{Binding IsToday, Converter={StaticResource BoolToColorConverter}}"/>
                                <Label Text="{Binding ShortDate}"
                                       FontSize="13" TextColor="Gray"/>
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="+ Add"
                                    BackgroundColor="#A62B60"
                                    TextColor="White"
                                    FontSize="13"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MealPlannerViewModel}}, Path=AddMealCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>

                        <!-- Meals for this day -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Meals}" Spacing="6">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:MealPlan">
                                    <Frame BackgroundColor="White" CornerRadius="8"
                                           Padding="12" HasShadow="True">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <!-- Meal Type Badge -->
                                            <Frame Grid.Column="0"
                                                   BackgroundColor="#A62B60"
                                                   CornerRadius="6"
                                                   Padding="8,4"
                                                   HasShadow="False">
                                                <Label Text="{Binding MealType}"
                                                       FontSize="11"
                                                       TextColor="White"
                                                       FontAttributes="Bold"/>
                                            </Frame>

                                            <Label Grid.Column="1"
                                                   Text="{Binding RecipeName}"
                                                   FontSize="14"
                                                   TextColor="#333"
                                                   VerticalOptions="Center"
                                                   Margin="10,0"/>

                                            <Button Grid.Column="2"
                                                    Text="✕"
                                                    BackgroundColor="Transparent"
                                                    TextColor="Gray"
                                                    FontSize="14"
                                                    Padding="8,0"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MealPlannerViewModel}}, Path=RemoveMealCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" BackgroundColor="#EEE" Margin="0,5"/>

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>