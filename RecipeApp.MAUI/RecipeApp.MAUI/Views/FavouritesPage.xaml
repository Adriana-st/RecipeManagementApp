<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:RecipeApp.MAUI.ViewModels"
             xmlns:models="clr-namespace:RecipeApp.Shared;assembly=RecipeApp.Shared"
             x:Class="RecipeApp.MAUI.Views.FavouritesPage"
             x:DataType="viewmodel:FavouritesViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Frame Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Label Text="🤍 My Favourite Recipes"
                    Style="{StaticResource PageHeaderLabelStyle}"/>
        </Frame>

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding HasNoFavourites}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="15"
                             Padding="40">
            <Label Text="💔" FontSize="64" HorizontalTextAlignment="Center"/>
            <Label Text="No favourites yet!"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{StaticResource AppTextPrimary}"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Browse recipes and tap the heart to save them here."
                   FontSize="15"
                   TextColor="Gray"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Favourites List -->
        <RefreshView Grid.Row="1"
                     IsVisible="{Binding HasNoFavourites, Converter={StaticResource InvertedBoolConverter}}"
                     Command="{Binding LoadFavouritesCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Favourites}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Recipe">
                        <Grid Padding="15,8">
                            <Frame BackgroundColor="White" CornerRadius="10" Padding="0" HasShadow="True">
                                <Grid ColumnDefinitions="120,*,Auto">

                                    <!-- Image -->
                                    <Image Grid.Column="0"
                                           Source="{Binding DisplayImage}"
                                           Aspect="AspectFill"
                                           HeightRequest="100"
                                           WidthRequest="120"/>

                                    <!-- Info -->
                                    <VerticalStackLayout Grid.Column="1" Padding="12" Spacing="4" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource AppTextPrimary}"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding CuisineType}"
                                               FontSize="13"
                                               TextColor="{StaticResource AppPrimary}"/>
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="{Binding Difficulty}" FontSize="12" TextColor="Gray"/>
                                            <Label Text="•" TextColor="Gray" FontSize="12"/>
                                            <Label Text="{Binding TotalTimeMinutes, StringFormat='{0} min'}"
                                                   FontSize="12" TextColor="Gray"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Remove Button -->
                                    <Button Grid.Column="2"
                                            Text="💔"
                                            FontSize="20"
                                            BackgroundColor="Transparent"
                                            Padding="10"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:FavouritesViewModel}}, Path=RemoveFavouriteCommand}"
                                            CommandParameter="{Binding .}"/>

                                </Grid>

                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:FavouritesViewModel}}, Path=GoToRecipeDetailCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Frame.GestureRecognizers>
                            </Frame>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>