<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:RecipeApp.MAUI.ViewModels"
             x:Class="RecipeApp.MAUI.Views.AddRecipePage"
             x:DataType="viewmodel:AddRecipeViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Header -->
            <Frame BackgroundColor="#A62B60" CornerRadius="10" Padding="20" HasShadow="False">
                <Label Text="➕ Add Custom Recipe"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="White" HorizontalTextAlignment="Center"/>
            </Frame>

            <!-- Basic Info -->
            <Label Text="Basic Information"
                   FontSize="18" FontAttributes="Bold" TextColor="#A62B60"/>

            <Entry Placeholder="Recipe Name *"
                   Text="{Binding Name}"
                   FontSize="15"/>

            <Editor Placeholder="Description (optional)"
                    Text="{Binding Description}"
                    FontSize="15"
                    HeightRequest="80"
                    AutoSize="TextChanges"/>

            <!-- Cuisine Dropdown -->
            <Picker Title="Cuisine Type"
                    ItemsSource="{Binding CuisineOptions}"
                    SelectedItem="{Binding SelectedCuisine}"/>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="Prep (min)" FontSize="12" TextColor="Gray"/>
                    <Entry Text="{Binding PrepTimeMinutes}" Keyboard="Numeric" FontSize="15"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="4">
                    <Label Text="Cook (min)" FontSize="12" TextColor="Gray"/>
                    <Entry Text="{Binding CookTimeMinutes}" Keyboard="Numeric" FontSize="15"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" Spacing="4">
                    <Label Text="Servings" FontSize="12" TextColor="Gray"/>
                    <Entry Text="{Binding Servings}" Keyboard="Numeric" FontSize="15"/>
                </VerticalStackLayout>
            </Grid>

            <Picker Title="Difficulty"
                    ItemsSource="{Binding DifficultyOptions}"
                    SelectedItem="{Binding SelectedDifficulty}"/>

            <!-- Image URL -->
            <Label Text="📷 Recipe Image"
                   FontSize="18" FontAttributes="Bold" TextColor="#A62B60"
                   Margin="0,10,0,0"/>

            <Entry Placeholder="Image URL (optional)"
                   Text="{Binding ImageUrl}"
                   FontSize="15"
                   Keyboard="Url"/>

            <!-- Image Preview -->
            <Frame IsVisible="{Binding ImageUrl, Converter={StaticResource IsNotNullOrEmptyConverter}}"
                   CornerRadius="10" Padding="0" HasShadow="True"
                   HeightRequest="200" IsClippedToBounds="True">
                <Image Source="{Binding ImageUrl}"
                       Aspect="AspectFill"/>
            </Frame>

            <!-- Ingredients -->
            <Label Text="🥗 Ingredients *"
                   FontSize="18" FontAttributes="Bold" TextColor="#A62B60"
                   Margin="0,10,0,0"/>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Entry Grid.Column="0"
                       Placeholder="Add ingredient..."
                       Text="{Binding NewIngredient}"
                       FontSize="15"
                       ReturnCommand="{Binding AddIngredientCommand}"/>
                <Button Grid.Column="1" Text="Add"
                        BackgroundColor="#A62B60" TextColor="White"
                        CornerRadius="8"
                        Command="{Binding AddIngredientCommand}"/>
            </Grid>

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Ingredients}" Spacing="8">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid ColumnDefinitions="*,Auto">
                            <Frame Grid.Column="0" BackgroundColor="#FFF5F8"
                                   CornerRadius="8" Padding="12" HasShadow="False">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="•" TextColor="#A62B60" FontSize="16"/>
                                    <Label Text="{Binding .}" FontSize="15"/>
                                </HorizontalStackLayout>
                            </Frame>
                            <Button Grid.Column="1" Text="✕"
                                    BackgroundColor="Transparent"
                                    TextColor="Gray" FontSize="16"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:AddRecipeViewModel}}, Path=RemoveIngredientCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Instructions -->
            <Label Text="📋 Instructions *"
                   FontSize="18" FontAttributes="Bold" TextColor="#A62B60"
                   Margin="0,10,0,0"/>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Editor Grid.Column="0"
                        Placeholder="Add instruction step..."
                        Text="{Binding NewInstruction}"
                        FontSize="15"
                        HeightRequest="80"
                        AutoSize="TextChanges"/>
                <Button Grid.Column="1" Text="Add"
                        BackgroundColor="#A62B60" TextColor="White"
                        CornerRadius="8" VerticalOptions="End"
                        Command="{Binding AddInstructionCommand}"/>
            </Grid>

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Instructions}" Spacing="8">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid ColumnDefinitions="*,Auto">
                            <Frame Grid.Column="0" BackgroundColor="#FFF5F8"
                                   CornerRadius="8" Padding="12" HasShadow="False">
                                <Label Text="{Binding .}" FontSize="15"/>
                            </Frame>
                            <Button Grid.Column="1" Text="✕"
                                    BackgroundColor="Transparent"
                                    TextColor="Gray" FontSize="16"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:AddRecipeViewModel}}, Path=RemoveInstructionCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Save Button -->
            <Button Text="💾 Save Recipe"
                    BackgroundColor="#A62B60"
                    TextColor="White"
                    FontSize="18" FontAttributes="Bold"
                    CornerRadius="10" Padding="15"
                    Margin="0,20,0,40"
                    Command="{Binding SaveRecipeCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>