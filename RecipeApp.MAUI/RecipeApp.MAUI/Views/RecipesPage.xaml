<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:RecipeApp.MAUI.ViewModels"
             xmlns:models="clr-namespace:RecipeApp.Shared;assembly=RecipeApp.Shared"
             x:Class="RecipeApp.MAUI.Views.RecipesPage"
             x:DataType="viewmodel:RecipesViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Search Bar Row -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
              Padding="15,10" ColumnSpacing="10"
              BackgroundColor="#F5F5F5">
            <SearchBar Grid.Column="0"
                       Placeholder="Search by dish name or ingredient..."
                       Text="{Binding SearchText}"
                       SearchCommand="{Binding ApplyFiltersCommand}"
                       BackgroundColor="White"/>
            <Button Grid.Column="1"
                    Text="Filter"
                    BackgroundColor="{Binding FiltersVisible, Converter={StaticResource BoolToFilterButtonColorConverter}}"
                    TextColor="White"
                    CornerRadius="8"
                    Padding="12,0"
                    Clicked="OnToggleFiltersClicked"/>
        </Grid>

        <!-- Collapsible Filter Panel -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding FiltersVisible}"
                             BackgroundColor="#EFEFEF"
                             Padding="15,10" Spacing="8">

            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                <Picker Grid.Column="0"
                        Title="Cuisine"
                        ItemsSource="{Binding CuisineOptions}"
                        SelectedItem="{Binding SelectedCuisine}"
                        FontSize="13"
                        SelectedIndexChanged="OnFilterChanged"/>
                <Picker Grid.Column="1"
                        Title="Difficulty"
                        ItemsSource="{Binding DifficultyOptions}"
                        SelectedItem="{Binding SelectedDifficulty}"
                        FontSize="13"
                        SelectedIndexChanged="OnFilterChanged"/>
                <Picker Grid.Column="2"
                        Title="Protein"
                        ItemsSource="{Binding ProteinOptions}"
                        SelectedItem="{Binding SelectedProtein}"
                        FontSize="13"
                        SelectedIndexChanged="OnFilterChanged"/>

                <VerticalStackLayout Grid.Column="3" Spacing="2">
                    <Label Text="{Binding MaxTime, StringFormat='Max: {0} min'}"
                           FontSize="11" TextColor="Gray"
                           HorizontalTextAlignment="Center"/>
                    <Slider Minimum="10" Maximum="300"
                            Value="{Binding MaxTime}"
                            DragCompleted="OnSliderDragCompleted"
                            ThumbColor="{StaticResource AppPrimary}"
                            MinimumTrackColor="{StaticResource AppPrimary}"/>
                </VerticalStackLayout>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="Apply Filters"
                        Style="{StaticResource PrimaryButtonStyle}" 
                        FontSize="13" 
                        Clicked="OnApplyFiltersClicked"/>
                <Button Grid.Column="1"
                        Text="Reset"
                        Style="{StaticResource SecondaryButtonStyle}" 
                        FontSize="13" 
                        Clicked="OnResetFiltersClicked"/>
            </Grid>

        </VerticalStackLayout>

        <!-- Recipes List -->
        <RefreshView Grid.Row="2"
                     Command="{Binding LoadRecipesCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Recipes}" SelectionMode="None">

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="10" Padding="40">
                        <Label Text="No recipes found"
                               FontSize="18" TextColor="Gray"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Recipe">
                        <Grid Padding="15,8">
                            <Frame BackgroundColor="White" CornerRadius="10"
                                   Padding="0" HasShadow="True"
                                   IsClippedToBounds="True">

                                <Grid ColumnDefinitions="150,*">

                                    <!-- Image -->
                                    <Image Grid.Column="0"
                                           Source="{Binding DisplayImage}"
                                           Aspect="AspectFill"
                                           HeightRequest="180"
                                           WidthRequest="150"/>

                                    <!-- Info + Buttons -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="12,10"
                                                         Spacing="6"
                                                         VerticalOptions="FillAndExpand">

                                        <!-- Name -->
                                        <Label Text="{Binding Name}"
                                               FontSize="16" FontAttributes="Bold"
                                               TextColor="{StaticResource AppTextPrimary}"
                                               LineBreakMode="TailTruncation"/>

                                        <!-- Cuisine + Custom Badge -->
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding CuisineType}"
                                                   FontSize="13" TextColor="{StaticResource AppPrimary}"/>
                                            <Frame IsVisible="{Binding IsCustom}"
                                                   BackgroundColor="{StaticResource AppAccent}"
                                                   CornerRadius="4" Padding="6,2"
                                                   HasShadow="False">
                                                <Label Text="Custom"
                                                       FontSize="11" TextColor="White"/>
                                            </Frame>
                                        </HorizontalStackLayout>

                                        <!-- Time + Servings + Difficulty -->
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding TotalTimeMinutes, StringFormat='{0} min'}"
                                                   FontSize="12" TextColor="Gray"/>
                                            <Label Text="|" TextColor="#DDD" FontSize="12"/>
                                            <Label Text="{Binding Servings, StringFormat='{0} srv'}"
                                                   FontSize="12" TextColor="Gray"/>
                                            <Label Text="|" TextColor="#DDD" FontSize="12"/>
                                            <Label Text="{Binding Difficulty}"
                                                   FontSize="12" TextColor="Gray"/>
                                        </HorizontalStackLayout>

                                        <!-- Ingredients preview -->
                                        <Label Text="{Binding IngredientsDisplay}"
                                               FontSize="12" TextColor="#888"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2"/>

                                        <!-- Spacer -->
                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="#EEE"
                                                 Margin="0,4"/>

                                        <!-- Buttons -->
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <Button Grid.Column="0"
                                                    Text="{Binding IsFavourite, Converter={StaticResource BoolToSaveTextConverter}}"
                                                    BackgroundColor="{Binding IsFavourite, Converter={StaticResource BoolToSaveColorConverter}}"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    CornerRadius="8"
                                                    Padding="8,6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:RecipesViewModel}}, Path=ToggleFavouriteCommand}"
                                                    CommandParameter="{Binding .}"/>

                                            <Button Grid.Column="1"
                                                    Text="View Details"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    CornerRadius="8"
                                                    Padding="8,6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:RecipesViewModel}}, Path=GoToRecipeDetailCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>

                                    </VerticalStackLayout>
                                </Grid>

                            </Frame>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>