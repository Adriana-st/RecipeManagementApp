<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:RecipeApp.MAUI.ViewModels"
             xmlns:models="clr-namespace:RecipeApp.MAUI.Models"
             x:Class="RecipeApp.MAUI.Views.RecipesPage"
             x:DataType="viewmodel:RecipesViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">

        <!-- Search & Filter Panel -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="#F5F5F5" Padding="15" Spacing="10">

            <SearchBar Placeholder="Search recipes..."
                       Text="{Binding SearchText}"
                       SearchCommand="{Binding ApplyFiltersCommand}"
                       BackgroundColor="White"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Picker Grid.Column="0"
                        Title="Cuisine"
                        ItemsSource="{Binding CuisineOptions}"
                        SelectedItem="{Binding SelectedCuisine}"
                        SelectedIndexChanged="OnFilterChanged"/>

                <Picker Grid.Column="1"
                        Title="Difficulty"
                        ItemsSource="{Binding DifficultyOptions}"
                        SelectedItem="{Binding SelectedDifficulty}"
                        SelectedIndexChanged="OnFilterChanged"/>
            </Grid>
        </VerticalStackLayout>

        <!-- Recipes List -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadRecipesCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Recipes}"
                            SelectionMode="None">

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="40">
                        <Label Text="🍽️" FontSize="48" HorizontalTextAlignment="Center"/>
                        <Label Text="No recipes found" FontSize="18" TextColor="Gray" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Recipe">
                        <Grid Padding="15,8">
                            <Frame BackgroundColor="White" CornerRadius="10" Padding="0" HasShadow="True">
                                <Grid ColumnDefinitions="120,*" >

                                    <!-- Recipe Image -->
                                    <Image Grid.Column="0"
                                           Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           HeightRequest="100"
                                           WidthRequest="120"/>

                                    <!-- Recipe Info -->
                                    <VerticalStackLayout Grid.Column="1" Padding="12" Spacing="4" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#333"
                                               LineBreakMode="TailTruncation"/>

                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding CuisineType}"
                                                   FontSize="13"
                                                   TextColor="#A62B60"/>    
                                            <Frame IsVisible="{Binding IsCustom}"
                                                   BackgroundColor="#97BC62"
                                                   CornerRadius="4"
                                                   Padding="6,2"
                                                   HasShadow="False">
                                                <Label Text="⭐ Custom"
                                                       FontSize="11"
                                                       TextColor="White"/>
                                            </Frame>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="{Binding Difficulty}"
                                                   FontSize="12"
                                                   TextColor="Gray"/>
                                            <Label Text="•" TextColor="Gray" FontSize="12"/>
                                            <Label Text="{Binding TotalTimeMinutes, StringFormat='{0} min'}"
                                                   FontSize="12"
                                                   TextColor="Gray"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                </Grid>

                                <!-- Tap gesture -->
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:RecipesViewModel}}, Path=GoToRecipeDetailCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Frame.GestureRecognizers>
                            </Frame>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>