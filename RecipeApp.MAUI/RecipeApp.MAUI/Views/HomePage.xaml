<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:RecipeApp.MAUI.ViewModels"
             x:Class="RecipeApp.MAUI.Views.HomePage"
             x:DataType="viewmodel:HomeViewModel"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Frame BackgroundColor="#A62B60" CornerRadius="10" Padding="30" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🍳 Recipe Management App"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="{Binding WelcomeMessage}"
                           FontSize="14"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Stats Cards -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">

                <!-- Total Recipes Card -->
                <Frame Grid.Column="0" 
                       BackgroundColor="White" 
                       CornerRadius="10" 
                       Padding="20"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="📚"
                               FontSize="32"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding TotalRecipes}"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="#A62B60"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Total Recipes"
                               FontSize="12"
                               TextColor="Gray"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Favourites Card -->
                <Frame Grid.Column="1" 
                       BackgroundColor="White" 
                       CornerRadius="10" 
                       Padding="20"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="❤️"
                               FontSize="32"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding FavouriteCount}"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="#97BC62"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="My Favourites"
                               FontSize="12"
                               TextColor="Gray"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Quick Actions -->
            <Label Text="Quick Actions"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#A62B60"
                   Margin="0,20,0,0"/>

            <Button Text="📖 Browse Recipes"
                    BackgroundColor="#A62B60"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    Padding="15"
                    Clicked="OnBrowseRecipesClicked"/>

            <Button Text="❤️ My Favourites"
                    BackgroundColor="#97BC62"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    Padding="15"
                    Clicked="OnFavouritesClicked"/>

            <Button Text="➕ Add Custom Recipe"
                    BackgroundColor="#A62B60"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    Padding="15"
                    Clicked="OnAddRecipeClicked"/>

            <Button Text="📅 Meal Planner"
                    BackgroundColor="#97BC62"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    Padding="15"
                    Clicked="OnMealPlannerClicked"/>

            <Button Text="🛒 Shopping List"
                    BackgroundColor="#A62B60"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    Padding="15"
                    Clicked="OnShoppingListClicked"/>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                              IsVisible="{Binding IsBusy}"
                              Color="#A62B60"
                              HeightRequest="50"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>